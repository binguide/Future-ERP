# OpenERP-X environment variables
# Copy to .env and adjust as needed

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=operp
DATABASE_PASSWORD=operp_secret
DATABASE_NAME=operp

# Valkey (Redis-compatible)
VALKEY_HOST=localhost
VALKEY_PORT=6379

# JWT
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars
JWT_EXPIRES_IN=1d

# API
PORT=4000
